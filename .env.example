# Copy to `.env` for local scripts (never commit `.env`).
# For dbt: use `python scripts/dbt_env.py debug` (dbt does not load .env by itself).

# Required — Snowflake auth (ingestion script + dbt profile)
SNOW_ACCOUNT=your_account_identifier
SNOW_USER=your_username
SNOW_USER_PASSWORD=your_password

# Optional — dbt profile defaults (see profiles.yml.example)
# SNOWFLAKE_ROLE=ACCOUNTADMIN
# SNOWFLAKE_DATABASE=dbt_project
# SNOWFLAKE_WAREHOUSE=COMPUTE_WH
